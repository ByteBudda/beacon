# ============================================
# QNTX.Beacon — Production Configuration
# ============================================

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=3333
DEBUG=false
LOG_LEVEL=info

# --- Database (SQLite) ---
DATABASE_URL=sqlite:///./data/beacon.db

# --- JWT ---
JWT_SECRET=<GENERATE_RANDOM_64_CHARS>
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# --- Email (SMTP) ---
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=qntx-info@list.ru
SMTP_PASSWORD=<YOUR_PASSWORD>
FROM_EMAIL=qntx-info@list.ru
FROM_NAME=QNTX.Beacon
SMTP_USE_SSL=true

# --- App ---
APP_NAME=Beacon
APP_URL=https://qntx.ru
DEFAULT_DOMAIN=qntx.ru
ADMIN_EMAIL=qntx-info@list.ru
ADMIN_PASSWORD=<YOUR_ADMIN_PASSWORD>

# --- Rate Limiting ---
RATE_LIMIT_REGISTER=3
RATE_LIMIT_LOGIN=5
RATE_LIMIT_CREATE_LINK=50
RATE_LIMIT_REDIRECT=200

# --- Plans ---
FREE_PLAN_LIMIT=50
PRO_PLAN_LIMIT=1000
PRO_PLAN_PRICE=299
BUSINESS_PLAN_LIMIT=999999
BUSINESS_PLAN_PRICE=999

# --- Payments (YooKassa) ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# --- QR Code ---
QR_CODE_SIZE=10
QR_CODE_BORDER=4

# --- Security ---
BCRYPT_ROUNDS=12
ALLOWED_ORIGINS=https://qntx.ru,http://localhost:*
TRUSTED_HOSTS=*

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=

# --- Background Tasks ---
CLEANUP_INTERVAL_SECONDS=3600